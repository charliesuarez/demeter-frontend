@page "/"
@using Main.Bluetooth
@using Main.Services
@using static MudBlazor.Icons
@inject IBluetoothService Bluetooth
@inject DatabaseService Db
@implements IDisposable

<style>
    .overview-header {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        color: white;
        padding: 2rem;
        border-radius: 8px;
        margin-bottom: 2rem;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    .stat-card {
        transition: all 0.3s ease;
        border: 2px solid #e5e7eb !important;
    }

    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 16px rgba(17, 153, 142, 0.2);
        border-color: #11998e !important;
    }

    .metric-card {
        transition: all 0.3s ease;
        border: 2px solid #A5D6A7 !important;
        background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%) !important;
    }

    .metric-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 12px rgba(17, 153, 142, 0.15);
    }

    .metric-card-warning {
        transition: all 0.3s ease;
        border: 2px solid #fbbf24 !important;
        background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%) !important;
    }

    .metric-card-warning:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 12px rgba(251, 191, 36, 0.2);
    }

    .metric-card-critical {
        transition: all 0.3s ease;
        border: 2px solid #ef4444 !important;
        background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%) !important;
    }

    .metric-card-critical:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 12px rgba(239, 68, 68, 0.2);
    }

    .alert-card {
        transition: all 0.3s ease;
    }

    .alert-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }

    .status-indicator {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        margin-right: 0.5rem;
    }

    .status-connected {
        background: #10b981;
        animation: pulse 2s infinite;
    }

    .status-disconnected {
        background: #ef4444;
    }

    @@keyframes pulse {
        0%, 100% {
            opacity: 1;
            box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
        }
        50% {
            opacity: 0.8;
            box-shadow: 0 0 0 8px rgba(16, 185, 129, 0);
        }
    }

    .live-badge {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        color: white;
        padding: 0.4rem 1rem;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .offline-badge {
        background: #6b7280;
        color: white;
        padding: 0.4rem 1rem;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.85rem;
    }

    .alert-item {
        padding: 0.75rem 1rem;
        border-radius: 8px;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 0.75rem;
    }

    .alert-warning {
        background-color: #fffbeb;
        border-left: 4px solid #f59e0b;
    }

    .alert-critical {
        background-color: #fef2f2;
        border-left: 4px solid #ef4444;
    }

    .alert-timestamp {
        font-size: 0.75rem;
        color: #9ca3af;
        margin-top: 0.2rem;
    }

    @@media (max-width: 600px) {
        .overview-header { padding: 1rem; }
        .overview-header h3 { font-size: 1.3rem; }
        .metric-card { padding: 8px !important; }
    }
</style>

<div class="overview-header">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <div>
            <h3 style="margin: 0; font-size: 1.8rem; font-weight: 600;">
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Style="vertical-align: middle; margin-right: 0.5rem;" />
                System Overview
            </h3>
            <p style="margin: 0.5rem 0 0 0; opacity: 0.9;">Real-time monitoring of your hydroponic system</p>
        </div>
        @if (!_isConnected)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Bluetooth"
                       OnClick="ShowConnectionDialog"
                       Style="background: white; color: #11998e;">
                Connect Device
            </MudButton>
        }
    </MudStack>
</div>

<MudButton OnClick="SimulateReading" Color="Color.Warning" Variant="Variant.Outlined" Class="mb-4">
    Simulate Bad Reading (Test)
</MudButton>

@* --- STAT CARDS --- *@
@{
    var alertIconColor = _alerts.Any(a => a.IsCritical) ? "#ef4444" : _alerts.Any() ? "#f59e0b" : "#11998e";
}
<MudGrid Spacing="4" Class="mb-6">
    <MudItem xs="6" sm="6" md="4">
        <MudPaper Elevation="0" Outlined="true" Class="pa-4 stat-card" Style="border-radius: 12px;">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.body2" Style="color: #6b7280; font-weight: 500;">Active Crops</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight: 700; color: #1f2937;">@_activeCropCount</MudText>
                </MudStack>
                <MudIcon Icon="@Icons.Material.Filled.Grass" Style="color: #11998e;" Size="Size.Large" />
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="6" sm="6" md="4">
        <MudPaper Elevation="0" Outlined="true" Class="pa-4 stat-card" Style="border-radius: 12px;">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.body2" Style="color: #6b7280; font-weight: 500;">Days Until Harvest</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight: 700; color: #1f2937;">@_daysUntilHarvest</MudText>
                </MudStack>
                <MudIcon Icon="@Icons.Material.Filled.Agriculture" Style="color: #11998e;" Size="Size.Large" />
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="6" sm="6" md="4">
        <MudPaper Elevation="0" Outlined="true" Class="pa-4 stat-card" Style="border-radius: 12px;">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.body2" Style="color: #6b7280; font-weight: 500;">Active Alerts</MudText>
                    <MudText Typo="Typo.h4" Style="font-weight: 700; color: #1f2937;">@_alerts.Count</MudText>
                </MudStack>
                <MudIcon Icon="@Icons.Material.Filled.Report" Style="@("color: " + alertIconColor + ";")" Size="Size.Large" />
            </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>

@* --- MAIN + SIDEBAR LAYOUT --- *@
<MudGrid Spacing="4">

    @* --- METRICS --- *@
    <MudItem xs="12" md="8">
        <MudPaper Elevation="2" Class="pa-3 pa-sm-5" Style="border-radius: 12px;">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Sensors" Style="color: #11998e;" Size="Size.Medium" />
                    <MudText Typo="Typo.h5" Style="font-weight: 600; color: #1f2937;">Environmental Metrics</MudText>
                </MudStack>
                @if (_isConnected)
                {
                    <div class="live-badge">
                        <MudIcon Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" />
                        <span>Live</span>
                    </div>
                }
                else
                {
                    <span class="offline-badge">Offline</span>
                }
            </MudStack>

            @{
                var phClass = "pa-3 " + GetMetricClass("ph");
                var waterTempClass = "pa-3 " + GetMetricClass("watertemp");
                var waterLevelClass = "pa-3 " + GetMetricClass("waterlevel");
                var doClass = "pa-3 " + GetMetricClass("do");
                var lightClass = "pa-3 " + GetMetricClass("light");
                var tdsClass = "pa-3 " + GetMetricClass("tds");
            }

            <MudGrid Spacing="3">
                <MudItem xs="6" sm="6">
                    <MudPaper Elevation="0" Outlined="true" Class="@phClass" Style="border-radius: 12px;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <div style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); padding: 8px; border-radius: 12px;">
                                <MudIcon Icon="@Icons.Material.Filled.InvertColors" Style="color: white;" Size="Size.Large" />
                            </div>
                            <MudStack Spacing="0" Style="flex: 1;">
                                <MudText Typo="Typo.body2" Style="color: #6b7280; font-weight: 500;">Solution pH</MudText>
                                <MudText Typo="Typo.h5" Style="font-weight: 700; color: #1f2937;">@FormatValue(_sensorData?.Ph, "F1")</MudText>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="6" sm="6">
                    <MudPaper Elevation="0" Outlined="true" Class="@waterTempClass" Style="border-radius: 12px;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <div style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); padding: 8px; border-radius: 12px;">
                                <MudIcon Icon="@Icons.Material.Filled.Thermostat" Style="color: white;" Size="Size.Large" />
                            </div>
                            <MudStack Spacing="0" Style="flex: 1;">
                                <MudText Typo="Typo.body2" Style="color: #6b7280; font-weight: 500;">Water Temp</MudText>
                                <MudText Typo="Typo.h5" Style="font-weight: 700; color: #1f2937;">@FormatValue(_sensorData?.WaterTemp, "F1", "°C")</MudText>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="6" sm="6">
                    <MudPaper Elevation="0" Outlined="true" Class="@waterLevelClass" Style="border-radius: 12px;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <div style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); padding: 8px; border-radius: 12px;">
                                <MudIcon Icon="@Icons.Material.Filled.Water" Style="color: white;" Size="Size.Large" />
                            </div>
                            <MudStack Spacing="0" Style="flex: 1;">
                                <MudText Typo="Typo.body2" Style="color: #6b7280; font-weight: 500;">Water Level</MudText>
                                <MudText Typo="Typo.h5" Style="font-weight: 700; color: #1f2937;">@FormatValue(_sensorData?.WaterLevel, "F1", "%")</MudText>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="6" sm="6">
                    <MudPaper Elevation="0" Outlined="true" Class="@doClass" Style="border-radius: 12px;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <div style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); padding: 8px; border-radius: 12px;">
                                <MudIcon Icon="@Icons.Material.Filled.Air" Style="color: white;" Size="Size.Large" />
                            </div>
                            <MudStack Spacing="0" Style="flex: 1;">
                                <MudText Typo="Typo.body2" Style="color: #6b7280; font-weight: 500;">Dissolved O₂</MudText>
                                <MudText Typo="Typo.h5" Style="font-weight: 700; color: #1f2937;">@FormatValue(_sensorData?.DissolvedOxygen, "F1", " mg/L")</MudText>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="6" sm="6">
                    <MudPaper Elevation="0" Outlined="true" Class="@lightClass" Style="border-radius: 12px;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <div style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); padding: 8px; border-radius: 12px;">
                                <MudIcon Icon="@Icons.Material.Filled.WbSunny" Style="color: white;" Size="Size.Large" />
                            </div>
                            <MudStack Spacing="0" Style="flex: 1;">
                                <MudText Typo="Typo.body2" Style="color: #6b7280; font-weight: 500;">Light</MudText>
                                <MudText Typo="Typo.h5" Style="font-weight: 700; color: #1f2937;">@FormatValue(_sensorData?.Light, "F0", " lux")</MudText>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <MudItem xs="6" sm="6">
                    <MudPaper Elevation="0" Outlined="true" Class="@tdsClass" Style="border-radius: 12px;">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <div style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); padding: 8px; border-radius: 12px;">
                                <MudIcon Icon="@Icons.Material.Filled.Bolt" Style="color: white;" Size="Size.Large" />
                            </div>
                            <MudStack Spacing="0" Style="flex: 1;">
                                <MudText Typo="Typo.body2" Style="color: #6b7280; font-weight: 500;">TDS</MudText>
                                <MudText Typo="Typo.h5" Style="font-weight: 700; color: #1f2937;">@FormatValue(_sensorData?.Tds, "F0", " ppm")</MudText>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudItem>

    @* --- SIDEBAR --- *@
    <MudItem xs="12" md="4">

        @* Connection Card *@
        <MudPaper Elevation="2" Class="pa-4 mb-4 alert-card" Style="border-radius: 12px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Bluetooth" Style="color: #11998e;" Size="Size.Medium" />
                <MudText Typo="Typo.h6" Style="font-weight: 600; color: #1f2937;">Connection</MudText>
            </MudStack>
            @{
                var connBg = _isConnected ? "linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%)" : "#fef2f2";
                var connStyle = "padding: 1rem; background: " + connBg + "; border-radius: 8px;";
            }
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="@connStyle">
                <div class="status-indicator @(_isConnected ? "status-connected" : "status-disconnected")"></div>
                @if (_isConnected)
                {
                    <MudStack Spacing="0">
                        <MudText Style="color: #10b981; font-weight: 600;">@Bluetooth.ConnectedDeviceName</MudText>
                        <MudText Typo="Typo.caption" Style="color: #6b7280;">Connected</MudText>
                    </MudStack>
                }
                else
                {
                    <MudText Style="color: #ef4444; font-weight: 600;">Not Connected</MudText>
                }
            </MudStack>
            @if (_isConnected)
            {
                <MudButton Variant="Variant.Text" Color="Color.Error" FullWidth="true" Class="mt-3" OnClick="DisconnectAsync">
                    Disconnect
                </MudButton>
            }
        </MudPaper>

        @* Pump Controls Card *@
        <MudPaper Elevation="2" Class="pa-4 mb-4 alert-card" Style="border-radius: 12px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Style="color: #11998e;" Size="Size.Medium" />
                <MudText Typo="Typo.h6" Style="font-weight: 600; color: #1f2937;">Pump Controls</MudText>
            </MudStack>
            <MudStack Spacing="2">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudText>Water Pump</MudText>
                    <MudSwitch T="bool" Value="_waterPumpOn" ValueChanged="OnWaterPumpToggle"
                               Color="Color.Success" Disabled="@(!_isConnected)" />
                </MudStack>
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudText>Air Pump</MudText>
                    <MudSwitch T="bool" Value="_airPumpOn" ValueChanged="OnAirPumpToggle"
                               Color="Color.Success" Disabled="@(!_isConnected)" />
                </MudStack>
                <MudDivider Class="my-2" />
                <MudText Typo="Typo.body2" Style="color: #6b7280;">Nutrient Dosing</MudText>
                <MudStack Row="true" Spacing="2">
                    <MudTextField T="int" @bind-Value="_doseDuration" Label="Duration (ms)"
                                  Variant="Variant.Outlined" Style="flex: 1;" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="DoseNutrientsAsync" Disabled="@(!_isConnected)"
                               Style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);">
                        Dose
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>

        @* Alerts Card *@
        <MudPaper Elevation="2" Class="pa-4 alert-card" Style="border-radius: 12px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Notifications" Style="color: #11998e;" Size="Size.Medium" />
                <MudText Typo="Typo.h6" Style="font-weight: 600; color: #1f2937;">Alerts</MudText>
            </MudStack>

            @if (!_alerts.Any())
            {
                <MudText Typo="Typo.body2" Style="color: #6b7280;">No active alerts</MudText>
            }
            else
            {
                @foreach (var alert in _alerts.OrderByDescending(a => a.IsCritical))
                {
                    var alertClass = "alert-item " + (alert.IsCritical ? "alert-critical" : "alert-warning");
                    var alertIconStyle = "color: " + (alert.IsCritical ? "#ef4444" : "#f59e0b") + ";";
                    var alertIcon = alert.IsCritical ? Icons.Material.Filled.Error : Icons.Material.Filled.Warning;
                    <div class="@alertClass">
                        <MudStack Row="false" Spacing="0" Style="flex: 1;">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@alertIcon" Style="@alertIconStyle" Size="Size.Small" />
                                <MudText Style="font-weight: 500; color: #1f2937; font-size: 0.85rem;">@alert.Message</MudText>
                            </MudStack>
                            <div class="alert-timestamp">@alert.Timestamp.ToString("hh:mm tt")</div>
                        </MudStack>
                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                       Size="Size.Small"
                                       Style="color: #9ca3af; padding: 2px;"
                                       OnClick="() => DismissAlert(alert)" />
                    </div>
                }
            }

            <MudText Typo="Typo.caption" Style="color: #9ca3af; margin-top: 0.75rem; display: block;">
                Alerts refresh with each new sensor reading
            </MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

@* --- CONNECTION DIALOG --- *@
<MudDialog @bind-Visible="_showConnectionDialog" Options="_dialogOptions">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.BluetoothSearching" />
            <MudText Typo="Typo.h6">Connect to Demeter Controller</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_isScanning)
        {
            <MudStack AlignItems="AlignItems.Center" Spacing="3" Class="pa-4">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                <MudText>Scanning for devices...</MudText>
            </MudStack>
        }
        else if (_discoveredDevices.Count == 0)
        {
            <MudText Class="pa-4" Align="Align.Center" Style="color: #6b7280;">
                No devices found. Make sure your ESP32 is powered on.
            </MudText>
        }
        else
        {
            <MudList T="BleDevice" Dense="true">
                @foreach (var device in _discoveredDevices)
                {
                    <MudListItem OnClick="() => ConnectToDeviceAsync(device)">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width: 100%;">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body1" Style="font-weight: 600;">@device.Name</MudText>
                                <MudText Typo="Typo.caption" Style="color: #6b7280;">Signal: @GetSignalStrength(device.Rssi)</MudText>
                            </MudStack>
                            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" />
                        </MudStack>
                    </MudListItem>
                }
            </MudList>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showConnectionDialog = false">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="StartScanAsync" Disabled="_isScanning">
            @(_isScanning ? "Scanning..." : "Scan")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {

    private class LiveAlert
    {
        public string Sensor { get; set; } = "";
        public string Message { get; set; } = "";
        public bool IsCritical { get; set; }
        public DateTime Timestamp { get; set; }
    }

    private static class Thresholds
    {
        public const double PhWarnLow = 5.8, PhWarnHigh = 6.2;
        public const double PhCritLow = 5.5, PhCritHigh = 6.5;
        public const double WaterTempWarnLow = 19, WaterTempWarnHigh = 23;
        public const double WaterTempCritLow = 18, WaterTempCritHigh = 24;
        public const double AirTempWarnLow = 17, AirTempWarnHigh = 25;
        public const double AirTempCritLow = 16, AirTempCritHigh = 26;
        public const double HumidityWarnLow = 55, HumidityWarnHigh = 65;
        public const double HumidityCritLow = 50, HumidityCritHigh = 70;
        public const double TdsWarnLow = 500, TdsWarnHigh = 700;
        public const double TdsCritLow = 400, TdsCritHigh = 800;
        public const double DoWarnLow = 7;
        public const double DoCritLow = 6;
        public const double WaterLevelWarnLow = 30;
        public const double WaterLevelCritLow = 20;
        public const double LightWarnLow = 2500, LightWarnHigh = 3500;
        public const double LightCritLow = 2000, LightCritHigh = 4000;
    }

    private bool _isConnected;
    private bool _isScanning;
    private bool _showConnectionDialog;
    private SensorData? _sensorData;
    private List<BleDevice> _discoveredDevices = new();
    private List<LiveAlert> _alerts = new();
    private HashSet<string> _dismissedSensors = new();

    private bool _waterPumpOn;
    private bool _airPumpOn;
    private int _doseDuration = 1000;

    private int _activeCropCount = 0;
    private string _daysUntilHarvest = "--";

    private static readonly Dictionary<string, int> LettuceGrowDays = new()
    {
        { "Romaine Lettuce", 50 },
        { "Butterhead Lettuce", 45 },
        { "Iceberg Lettuce", 55 },
        { "Looseleaf Lettuce", 40 }
    };

    private DialogOptions _dialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true };

    protected override async Task OnInitializedAsync()
    {
        Bluetooth.SensorDataReceived += OnSensorDataReceived;
        Bluetooth.ConnectionChanged += OnConnectionChanged;
        Bluetooth.DeviceDiscovered += OnDeviceDiscovered;
        Bluetooth.ErrorOccurred += OnError;

        await Bluetooth.InitializeAsync();
        await LoadStatsAsync();
    }

    private async Task LoadStatsAsync()
    {
        var activeBatch = await Db.GetActiveBatchAsync();
        if (activeBatch != null)
        {
            var crops = await Db.GetCropsByBatchAsync(activeBatch.Id);
            var activeCrops = crops.Where(c => c.EndDate == null).ToList();
            _activeCropCount = activeCrops.Count;

            if (activeCrops.Any())
            {
                var earliest = activeCrops
                    .Where(c => LettuceGrowDays.ContainsKey(c.Type))
                    .Select(c => c.StartDate.AddDays(LettuceGrowDays[c.Type]))
                    .OrderBy(d => d)
                    .FirstOrDefault();

                if (earliest != default)
                {
                    var days = (earliest - DateTime.Now).Days;
                    _daysUntilHarvest = days > 0 ? days.ToString() : "Ready!";
                }
            }
        }
        else
        {
            _activeCropCount = 0;
            _daysUntilHarvest = "--";
        }
    }

    private void OnSensorDataReceived(SensorData data)
    {
        _sensorData = data;
        _dismissedSensors.Clear();
        BuildAlerts(data);
        SaveReadingToDatabase(data);
        InvokeAsync(StateHasChanged);
    }

    private void SaveReadingToDatabase(SensorData data)
    {
        _ = Task.Run(async () =>
        {
            var activeBatch = await Db.GetActiveBatchAsync();
            if (activeBatch == null) return;

            var reading = new SensorReading
            {
                BatchId = activeBatch.Id,
                Timestamp = DateTime.Now,
                Ph = data.Ph ?? 0,
                WaterTemp = data.WaterTemp ?? 0,
                AirTemp = data.AirTemp ?? 0,
                Humidity = data.Humidity ?? 0,
                Tds = data.Tds ?? 0,
                Ec = data.Tds ?? 0,
                WaterLevel = data.WaterLevel ?? 0,
                ReservoirLevel = data.WaterLevel ?? 0,
                LightIntensity = data.Light ?? 0,
                DissolvedOxygen = data.DissolvedOxygen ?? 0
            };

            await Db.SaveReadingAsync(reading);
        });
    }

    private void OnConnectionChanged(bool connected)
    {
        _isConnected = connected;
        _showConnectionDialog = false;

        if (!connected)
        {
            _sensorData = null;
            _waterPumpOn = false;
            _airPumpOn = false;
            _alerts.Clear();
        }

        InvokeAsync(StateHasChanged);
    }

    private void OnDeviceDiscovered(BleDevice device)
    {
        if (!_discoveredDevices.Any(d => d.Id == device.Id))
        {
            _discoveredDevices.Add(device);
            InvokeAsync(StateHasChanged);
        }
    }

    private void OnError(string message)
    {
        _alerts.Add(new LiveAlert
        {
            Sensor = "system",
            Message = message,
            IsCritical = true,
            Timestamp = DateTime.Now
        });
        InvokeAsync(StateHasChanged);
    }

    private void BuildAlerts(SensorData data)
    {
        _alerts.Clear();

        void Check(string sensor, double? value, double warnLow, double warnHigh, double critLow, double critHigh, string warnMsg, string critMsg)
        {
            if (value == null || _dismissedSensors.Contains(sensor)) return;
            if (value < critLow || value > critHigh)
                _alerts.Add(new LiveAlert { Sensor = sensor, Message = critMsg, IsCritical = true, Timestamp = DateTime.Now });
            else if (value < warnLow || value > warnHigh)
                _alerts.Add(new LiveAlert { Sensor = sensor, Message = warnMsg, IsCritical = false, Timestamp = DateTime.Now });
        }

        void CheckLow(string sensor, double? value, double warnLow, double critLow, string warnMsg, string critMsg)
        {
            if (value == null || _dismissedSensors.Contains(sensor)) return;
            if (value < critLow)
                _alerts.Add(new LiveAlert { Sensor = sensor, Message = critMsg, IsCritical = true, Timestamp = DateTime.Now });
            else if (value < warnLow)
                _alerts.Add(new LiveAlert { Sensor = sensor, Message = warnMsg, IsCritical = false, Timestamp = DateTime.Now });
        }

        Check("ph", data.Ph, Thresholds.PhWarnLow, Thresholds.PhWarnHigh, Thresholds.PhCritLow, Thresholds.PhCritHigh,
            $"pH is slightly off at {data.Ph:F1} — optimal range is 5.8–6.2",
            $"pH is critically off at {data.Ph:F1} — immediate adjustment needed");

        Check("watertemp", data.WaterTemp, Thresholds.WaterTempWarnLow, Thresholds.WaterTempWarnHigh, Thresholds.WaterTempCritLow, Thresholds.WaterTempCritHigh,
            $"Water temperature is {data.WaterTemp:F1}°C — slightly outside optimal range",
            $"Water temperature is critically {(data.WaterTemp < Thresholds.WaterTempCritLow ? "low" : "high")} at {data.WaterTemp:F1}°C");

        Check("airtemp", data.AirTemp, Thresholds.AirTempWarnLow, Thresholds.AirTempWarnHigh, Thresholds.AirTempCritLow, Thresholds.AirTempCritHigh,
            $"Air temperature is {data.AirTemp:F1}°C — slightly outside optimal range",
            $"Air temperature is critically {(data.AirTemp < Thresholds.AirTempCritLow ? "low" : "high")} at {data.AirTemp:F1}°C");

        Check("humidity", data.Humidity, Thresholds.HumidityWarnLow, Thresholds.HumidityWarnHigh, Thresholds.HumidityCritLow, Thresholds.HumidityCritHigh,
            $"Humidity is {data.Humidity:F0}% — slightly outside optimal range",
            $"Humidity is critically {(data.Humidity < Thresholds.HumidityCritLow ? "low" : "high")} at {data.Humidity:F0}%");

        Check("tds", data.Tds, Thresholds.TdsWarnLow, Thresholds.TdsWarnHigh, Thresholds.TdsCritLow, Thresholds.TdsCritHigh,
            $"Nutrient concentration is {data.Tds:F0} PPM — slightly outside optimal range",
            $"Nutrient concentration is critically {(data.Tds < Thresholds.TdsCritLow ? "low" : "high")} at {data.Tds:F0} PPM");

        CheckLow("do", data.DissolvedOxygen, Thresholds.DoWarnLow, Thresholds.DoCritLow,
            $"Dissolved oxygen is low at {data.DissolvedOxygen:F1} mg/L — check air pump",
            $"Dissolved oxygen is critically low at {data.DissolvedOxygen:F1} mg/L — plants may suffocate");

        CheckLow("waterlevel", data.WaterLevel, Thresholds.WaterLevelWarnLow, Thresholds.WaterLevelCritLow,
            $"Water level is low at {data.WaterLevel:F0}% — consider refilling soon",
            $"Water level is critically low at {data.WaterLevel:F0}% — refill immediately");

        Check("light", data.Light, Thresholds.LightWarnLow, Thresholds.LightWarnHigh, Thresholds.LightCritLow, Thresholds.LightCritHigh,
            $"Light intensity is {data.Light:F0} lux — slightly outside optimal range",
            $"Light intensity is critically {(data.Light < Thresholds.LightCritLow ? "low" : "high")} at {data.Light:F0} lux — check grow lights");
    }

    private void DismissAlert(LiveAlert alert)
    {
        _dismissedSensors.Add(alert.Sensor);
        _alerts.Remove(alert);
    }

    private string GetMetricClass(string sensor)
    {
        if (_sensorData == null) return "metric-card";

        bool isCritical = sensor switch
        {
            "ph" => _sensorData.Ph < Thresholds.PhCritLow || _sensorData.Ph > Thresholds.PhCritHigh,
            "watertemp" => _sensorData.WaterTemp < Thresholds.WaterTempCritLow || _sensorData.WaterTemp > Thresholds.WaterTempCritHigh,
            "waterlevel" => _sensorData.WaterLevel < Thresholds.WaterLevelCritLow,
            "do" => _sensorData.DissolvedOxygen < Thresholds.DoCritLow,
            "light" => _sensorData.Light < Thresholds.LightCritLow || _sensorData.Light > Thresholds.LightCritHigh,
            "tds" => _sensorData.Tds < Thresholds.TdsCritLow || _sensorData.Tds > Thresholds.TdsCritHigh,
            _ => false
        };

        bool isWarning = sensor switch
        {
            "ph" => _sensorData.Ph < Thresholds.PhWarnLow || _sensorData.Ph > Thresholds.PhWarnHigh,
            "watertemp" => _sensorData.WaterTemp < Thresholds.WaterTempWarnLow || _sensorData.WaterTemp > Thresholds.WaterTempWarnHigh,
            "waterlevel" => _sensorData.WaterLevel < Thresholds.WaterLevelWarnLow,
            "do" => _sensorData.DissolvedOxygen < Thresholds.DoWarnLow,
            "light" => _sensorData.Light < Thresholds.LightWarnLow || _sensorData.Light > Thresholds.LightWarnHigh,
            "tds" => _sensorData.Tds < Thresholds.TdsWarnLow || _sensorData.Tds > Thresholds.TdsWarnHigh,
            _ => false
        };

        if (isCritical) return "metric-card-critical";
        if (isWarning) return "metric-card-warning";
        return "metric-card";
    }

    private void ShowConnectionDialog()
    {
        _discoveredDevices.Clear();
        _showConnectionDialog = true;
    }

    private async Task StartScanAsync()
    {
        _isScanning = true;
        _discoveredDevices.Clear();
        StateHasChanged();
        await Bluetooth.StartScanAsync(timeoutSeconds: 10);
        _isScanning = false;
        StateHasChanged();
    }

    private async Task ConnectToDeviceAsync(BleDevice device)
    {
        try
        {
            await Bluetooth.StopScanAsync();
            await Bluetooth.ConnectAsync(device.Id);
        }
        catch (Exception ex)
        {
            _alerts.Add(new LiveAlert { Sensor = "system", Message = $"Connection failed: {ex.Message}", IsCritical = true, Timestamp = DateTime.Now });
        }
    }

    private async Task DisconnectAsync() => await Bluetooth.DisconnectAsync();

    private async Task OnWaterPumpToggle(bool value)
    {
        if (await Bluetooth.SetWaterPumpAsync(value)) _waterPumpOn = value;
    }

    private async Task OnAirPumpToggle(bool value)
    {
        if (await Bluetooth.SetAirPumpAsync(value)) _airPumpOn = value;
    }

    private async Task DoseNutrientsAsync()
    {
        if (await Bluetooth.DoseNutrientsAsync(_doseDuration))
            _alerts.Add(new LiveAlert { Sensor = "system", Message = $"Nutrient dosing started ({_doseDuration}ms)", IsCritical = false, Timestamp = DateTime.Now });
    }

    private string FormatValue(double? value, string format, string suffix = "")
        => value.HasValue ? $"{value.Value.ToString(format)}{suffix}" : "--";

    private string GetSignalStrength(int rssi) => rssi switch
    {
        > -50 => "Excellent",
        > -60 => "Good",
        > -70 => "Fair",
        _ => "Weak"
    };

    public void Dispose()
    {
        Bluetooth.SensorDataReceived -= OnSensorDataReceived;
        Bluetooth.ConnectionChanged -= OnConnectionChanged;
        Bluetooth.DeviceDiscovered -= OnDeviceDiscovered;
        Bluetooth.ErrorOccurred -= OnError;
    }

    private void SimulateReading()
    {
        var testData = new SensorData
        {
            Ph = 6.0,        // ✅ Normal (5.8–6.2)
            WaterTemp = 23.8, // ⚠️ Warning (above 23)
            WaterLevel = 25,  // ⚠️ Warning (below 30)
            DissolvedOxygen = 5.5, // 🔴 Critical (below 6)
            Light = 3100,    // ✅ Normal (2500–3500)
            Tds = 480,       // ⚠️ Warning (below 500)
            AirTemp = 21,    // ✅ Normal
            Humidity = 60    // ✅ Normal
        };

        _sensorData = testData;
        _dismissedSensors.Clear();
        BuildAlerts(testData);
        StateHasChanged();
    }
}
